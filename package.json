{
  "name": "career-os",
  "private": true,
  "version": "1.0.0",
  "description": "AI-Powered Career Operating System — See Your Future Before You Decide",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "cd apps/web && npx prisma generate",
    "db:push": "cd apps/web && npx prisma db push",
    "db:migrate": "cd apps/web && npx prisma migrate dev",
    "db:seed": "cd apps/web && npx prisma db seed",
    "db:seed-admin": "cd apps/web && npx tsx seed-admin.ts",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "prisma": {
    "seed": "tsx apps/web/src/lib/db/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
