  goalsNextWeek String   @db.Text
  projectsBuilt String   @db.Text
  jobsApplied   String   @db.Text
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccountabilityPartner {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  partnerEmail  String
  partnerName   String
  relation      String   // FRIEND, PARENT, SIBLING, STUDY_PARTNER
  status        String   @default("PENDING") // PENDING, ACCEPTED
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VaultDocument {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  title         String
  type          String   // RESUME, CV, CERTIFICATE, INTERNSHIP_PROOF, PROJECT, PORTFOLIO, GITHUB, LINKEDIN, WEBSITE, FREELANCE_PROFILE
  fileUrl       String?  @db.Text
  linkUrl       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
