{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tooling/typescript/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "coverage",
    "__tests__",
    "src/lib/db/seed*.ts",
    "src/lib/db/scratch",
    "seed-admin.ts",
    "seed-more.ts"
  ]
}
